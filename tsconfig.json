{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/App.tsx",
    "src/main.tsx",
    "src/components/AddPlayerModal.tsx",
    "src/components/Arena.tsx",
    "src/components/Dashboard.tsx",
    "src/components/Field.tsx",
    "src/components/Finance.tsx",
    "src/components/FinancialDashboardDemo.tsx",
    "src/components/Layout.tsx",
    "src/components/Logo.tsx",
    "src/components/Players.tsx",
    "src/components/Settings.tsx",
    "src/components/ui/financial-dashboard.tsx",
    "src/lib/supabase.ts",
    "src/lib/utils.ts",
    "vite.config.ts"
  ]
}
